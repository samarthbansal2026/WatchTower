# NOAA NCEI CDO v2 — request a token at https://www.ncei.noaa.gov/cdo-web/token
NCEI_CDO_TOKEN=

# Ticketmaster — Discovery API
# Signup: https://developer.ticketmaster.com/user/register
TICKETMASTER_CONSUMER_KEY=
TICKETMASTER_CONSUMER_SECRET=

# State DOT 511 systems (each free, separate signup)
# WSDOT (Washington): https://wsdot.wa.gov/traffic/api/
WSDOT_ACCESS_CODE=
# 511 SF Bay: https://511.org/open-data/token
SF_BAY_511_KEY=
# 511NY: https://511ny.org/developers/help
NY_511_KEY=

# Eventbrite — private token
# Account Settings → Developer Links → API Keys → create app → Private Token
# https://www.eventbrite.com/account-settings/apps
EVENTBRITE_PRIVATE_TOKEN=

# BallDontLie — sports schedules (NBA, NFL, MLB, NHL, MLS)
# Signup: https://www.balldontlie.io/
BALLDONTLIE_API_KEY=

# PredictHQ — academic events (graduation, exams, homecoming) + demand intelligence
# Signup: https://www.predicthq.com  →  Control Center → Settings → API Credentials
PREDICTHQ_TOKEN=

# FRED (Federal Reserve Economic Data) — St. Louis Fed
# Register and request key at https://fredaccount.stlouisfed.org/login/secure/ → My Account → API Keys
FRED_API_KEY=

# US Census Bureau — ACS (American Community Survey) demographic data
# Free key signup: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
